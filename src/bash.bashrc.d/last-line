## Attach _complete_alias to all aliases after bash-completion loads
## /etc/bash_completion.d/complete_alias. Skip if none (bare `complete -F` errors).
## Fork: https://github.com/cognition/complete-alias

if [[ -f /etc/bash_completion.d/complete_alias ]] \
    && declare -F _complete_alias >/dev/null 2>&1 \
    && ((${#BASH_ALIASES[@]} > 0)); then
    complete -F _complete_alias "${!BASH_ALIASES[@]}"
fi

