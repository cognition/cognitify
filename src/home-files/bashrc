BASE_PATH="/etc/bash.bashrc.d"

if [[ -f ~/.over-ride ]]; then
	source ~/.over-ride
fi


# shellcheck source=/dev/null
if [[ -f ${BASE_PATH}/bashrc_file ]]; then
    source ${BASE_PATH}/bashrc_file
fi


# shellcheck source=/dev/null
if [[ -f ${BASE_PATH}/last-line ]]; then
    source ${BASE_PATH}/last-line
fi

