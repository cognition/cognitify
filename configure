#!/usr/bin/env bash
# Cognitify configure script
# (c) 2026 Ramon Brooker <rbrooker@aeo3.io>

set -e

# Default values
PREFIX="${PREFIX:-/usr/local}"
ETC_DIR="${ETC_DIR:-/etc}"
HOME_DIR="${HOME_DIR:-$HOME}"
INSTALL_USER="${INSTALL_USER:-${SUDO_USER:-${USER}}}"
INCLUDE_GUI="${INCLUDE_GUI:-no}"
SKIP_PACKAGES="${SKIP_PACKAGES:-no}"
DOCKER_MODE="${DOCKER_MODE:-no}"
PACKAGE_TARGET="${PACKAGE_TARGET:-}"
INCLUDE_COCKPIT="${INCLUDE_COCKPIT:-no}"
EXTENDED_COMPLETIONS="${EXTENDED_COMPLETIONS:-no}"
EXTENDED_HOME_FILES="${EXTENDED_HOME_FILES:-no}"
HOSTNAME_COLOUR="${HOSTNAME_COLOUR:-}"
USERNAME_COLOUR="${USERNAME_COLOUR:-}"
PWD_COLOUR="${PWD_COLOUR:-}"
COLOUR_PROFILE="${COLOUR_PROFILE:-}"

# Output file
CONFIG_FILE="config.mk"

# Detect if running in Docker/container environment
detect_docker() {
    # Check for common Docker/container indicators
    if [[ -f /.dockerenv ]] || \
       [[ -n "${container:-}" ]] || \
       [[ -f /proc/1/cgroup ]] && grep -qa docker /proc/1/cgroup 2>/dev/null || \
       [[ -f /proc/1/cgroup ]] && grep -qa kubepods /proc/1/cgroup 2>/dev/null; then
        return 0
    fi
    return 1
}

# Detect distribution
# Uses the same detection logic as ddistro() in libCognitifyHelpers for consistency
# This function sets global variables needed for the build system
detect_distro() {
    # Source the appropriate OS release file to get distribution information
    # This matches the logic in ddistro() for consistency
    if [[ -f /etc/os-release ]]; then
        . /etc/os-release
        DISTRO_ID="$ID"
        DISTRO_VERSION_ID="$VERSION_ID"
        # Normalize RHEL ID variants
        if [[ "$ID" == "redhat" ]]; then
            DISTRO_ID="rhel"
        fi
    elif [[ -f /etc/oracle-release ]]; then
        . /etc/oracle-release
        DISTRO_ID="oracle"
    elif [[ -f /etc/redhat-release ]]; then
        # Fallback for older systems without /etc/os-release
        # Try to extract version from redhat-release
        if grep -qi "red hat enterprise" /etc/redhat-release 2>/dev/null; then
            DISTRO_ID="rhel"
            DISTRO_VERSION_ID=$(grep -oE '[0-9]+\.[0-9]+' /etc/redhat-release | head -1 || echo "")
        else
            DISTRO_ID="rhel"
        fi
    else
        DISTRO_ID="unknown"
    fi
    
    # Auto-detect Docker mode if not explicitly set
    if [[ "$DOCKER_MODE" = "no" ]] && detect_docker; then
        DOCKER_MODE="yes"
    fi

    # Determine package manager using command -v (matches improved ddistro() logic)
    # This ensures we detect what's actually available, not just what should be there
    if command -v apt-get >/dev/null 2>&1; then
        PKG_MANAGER="apt-get"
    elif command -v dnf >/dev/null 2>&1; then
        PKG_MANAGER="dnf"
    elif command -v yum >/dev/null 2>&1; then
        PKG_MANAGER="yum"
    elif command -v zypper >/dev/null 2>&1; then
        PKG_MANAGER="zypper"
    else
        PKG_MANAGER="unknown"
    fi

    # Set install and update commands based on detected package manager
    case "$PKG_MANAGER" in
        apt-get)
            PKG_MANAGER_INSTALL="apt-get install -y"
            PKG_MANAGER_UPDATE="apt-get update"
            ;;
        dnf)
            PKG_MANAGER_INSTALL="dnf install -y"
            PKG_MANAGER_UPDATE="dnf check-update || true"
            ;;
        yum)
            PKG_MANAGER_INSTALL="yum install -y"
            PKG_MANAGER_UPDATE="yum check-update || true"
            ;;
        zypper)
            PKG_MANAGER_INSTALL="zypper --non-interactive install --auto-agree-with-licenses"
            PKG_MANAGER_UPDATE="zypper refresh"
            ;;
        *)
            PKG_MANAGER_INSTALL=""
            PKG_MANAGER_UPDATE=""
            ;;
    esac
}

# Resolve package list profile when packages are installed
finalize_package_target() {
    if [[ "$SKIP_PACKAGES" == "yes" ]]; then
        return 0
    fi

    if [[ "$INCLUDE_GUI" == "yes" && "$DOCKER_MODE" == "yes" ]]; then
        echo "Error: GUI and Docker package lists cannot be combined. Use --package-target=host|docker|gui." >&2
        exit 1
    fi

    if [[ -n "$PACKAGE_TARGET" ]]; then
        case "$PACKAGE_TARGET" in
            host)
                DOCKER_MODE="no"
                INCLUDE_GUI="no"
                ;;
            docker)
                DOCKER_MODE="yes"
                INCLUDE_GUI="no"
                ;;
            gui)
                DOCKER_MODE="no"
                INCLUDE_GUI="yes"
                ;;
            *)
                echo "Error: Invalid --package-target='$PACKAGE_TARGET' (use host, docker, or gui)." >&2
                exit 1
                ;;
        esac
        return 0
    fi

    if [[ "$DOCKER_MODE" == "yes" ]]; then
        PACKAGE_TARGET="docker"
        INCLUDE_GUI="no"
        return 0
    fi

    if [[ "$INCLUDE_GUI" == "yes" ]]; then
        PACKAGE_TARGET="gui"
        DOCKER_MODE="no"
        return 0
    fi

    if detect_docker; then
        DOCKER_MODE="yes"
        PACKAGE_TARGET="docker"
        return 0
    fi

    cat <<EOF >&2
Error: Package installation is enabled but no package list profile was selected.

Choose exactly one of:
  --package-target=host    Standard systems (GENERAL package list)
  --package-target=docker  Containers and minimal hosts (GENERAL DOCKER list)
  --package-target=gui     Graphical workstations (GENERAL plus GENERAL_GUI)

Shorthand flags (equivalent to the above):
  --docker                 Same as --package-target=docker
  --include-gui            Same as --package-target=gui

To install files without any packages:
  --skip-packages

Re-run configure with one of these options, then run make install.
EOF
    exit 1
}

# Parse command line arguments
parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --prefix=*)
                PREFIX="${1#*=}"
                shift
                ;;
            --prefix)
                PREFIX="$2"
                shift 2
                ;;
            --etc-dir=*)
                ETC_DIR="${1#*=}"
                shift
                ;;
            --etc-dir)
                ETC_DIR="$2"
                shift 2
                ;;
            --user=*)
                INSTALL_USER="${1#*=}"
                shift
                ;;
            --user)
                INSTALL_USER="$2"
                shift 2
                ;;
            --root)
                INSTALL_USER="root"
                shift
                ;;
            --include-gui)
                INCLUDE_GUI="yes"
                shift
                ;;
            --include-cockpit)
                INCLUDE_COCKPIT="yes"
                shift
                ;;
            --skip-packages)
                SKIP_PACKAGES="yes"
                shift
                ;;
            --docker)
                DOCKER_MODE="yes"
                shift
                ;;
            --package-target=*)
                PACKAGE_TARGET="${1#*=}"
                shift
                ;;
            --package-target)
                PACKAGE_TARGET="$2"
                shift 2
                ;;
            --extended-completions)
                EXTENDED_COMPLETIONS="yes"
                shift
                ;;
            --extended-home-files)
                EXTENDED_HOME_FILES="yes"
                shift
                ;;
            --distro-package=*)
                DISTRO_PACKAGE="${1#*=}"
                shift
                ;;
            --distro-package)
                DISTRO_PACKAGE="$2"
                shift 2
                ;;
            --hostname-colour=*)
                HOSTNAME_COLOUR="${1#*=}"
                shift
                ;;
            --hostname-colour)
                HOSTNAME_COLOUR="$2"
                shift 2
                ;;
            --username-colour=*)
                USERNAME_COLOUR="${1#*=}"
                shift
                ;;
            --username-colour)
                USERNAME_COLOUR="$2"
                shift 2
                ;;
            --pwd-colour=*)
                PWD_COLOUR="${1#*=}"
                shift
                ;;
            --pwd-colour)
                PWD_COLOUR="$2"
                shift 2
                ;;
            --colour-profile=*)
                COLOUR_PROFILE="${1#*=}"
                shift
                ;;
            --colour-profile)
                COLOUR_PROFILE="$2"
                shift 2
                ;;
            --help|-h)
                cat <<EOF
Usage: $0 [OPTIONS]

Options:
  --prefix=DIR          Installation prefix (default: /usr/local)
  --etc-dir=DIR          System configuration directory (default: /etc)
  --user=USER            User to install dotfiles for (default: current user)
  --root                 Install dotfiles for root user (equivalent to --user=root)
  --include-gui          Include GUI packages (same as --package-target=gui)
  --include-cockpit      Add Cockpit packages from src/packages/COCKPIT
  --skip-packages        Skip package installation
  --docker               Use Docker/container package list (same as --package-target=docker)
  --package-target=PROFILE  Package profile when installing packages: host | docker | gui
                          Required on normal hosts unless you pass --docker, --include-gui,
                          or --skip-packages. Inside a container, docker is assumed if omitted.
  --extended-completions Install extended completions (kubectl, helm, terraform, etc.)
  --extended-home-files Install extended home files (terraformrc, shellcheckrc, etc.)
  --hostname-colour=COLOUR Set default hostname colour (e.g., AZURE, BRIGHT_PINK, OLIVE)
  --username-colour=COLOUR Set default username colour (e.g., LIME, GRAY, AZURE)
  --pwd-colour=COLOUR      Set default PWD colour (e.g., AZURE, LT_BLUE, BRIGHT_PINK)
  --colour-profile=PROFILE Set colour profile (use 'random' to randomly select from colour-combos)
                          When 'random' is used, sets hostname, username, and PWD colours
  --distro-package=DISTRO Create distribution-specific package (e.g., rocky, ubuntu)
  --help, -h             Show this help message

Environment variables:
  PREFIX                 Installation prefix
  ETC_DIR                System configuration directory
  INSTALL_USER           User for dotfiles installation
  INCLUDE_GUI            Set to 'yes' to include GUI packages
  INCLUDE_COCKPIT        Set to 'yes' to install Cockpit-related packages
  SKIP_PACKAGES          Set to 'yes' to skip package installation
  DOCKER_MODE            Set to 'yes' to use Docker/container mode
  PACKAGE_TARGET         host | docker | gui (explicit package list selection)
  EXTENDED_COMPLETIONS   Set to 'yes' to install extended completions
  EXTENDED_HOME_FILES    Set to 'yes' to install extended home files
  HOSTNAME_COLOUR        Set default hostname colour (e.g., AZURE, BRIGHT_PINK, OLIVE)
  USERNAME_COLOUR        Set default username colour (e.g., LIME, GRAY, AZURE)
  PWD_COLOUR             Set default PWD colour (e.g., AZURE, LT_BLUE, BRIGHT_PINK)
  COLOUR_PROFILE         Set colour profile (use 'random' to randomly select from colour-combos)
                         When 'random' is used, automatically sets HOSTNAME_COLOUR, USERNAME_COLOUR, and PWD_COLOUR

Examples:
  $0 --package-target=host
  $0 --package-target=host --include-cockpit
  $0 --prefix=/usr --include-gui
  $0 --user=john --skip-packages
  $0 --hostname-colour=AZURE
  $0 --hostname-colour=BRIGHT_PINK --skip-packages
  $0 --hostname-colour=AZURE --username-colour=LIME --pwd-colour=AZURE
  $0 --colour-profile=random
  $0 --colour-profile=random --skip-packages
EOF
                exit 0
                ;;
            *)
                echo "Unknown option: $1" >&2
                echo "Run '$0 --help' for usage information." >&2
                exit 1
                ;;
        esac
    done
}

# Parse colour-combos file and randomly select a combination
select_random_colour_profile() {
    # Try both .md and non-.md versions for backward compatibility
    local colour_file=""
    if [[ -f "colour-combos.md" ]]; then
        colour_file="colour-combos.md"
    elif [[ -f "colour-combos" ]]; then
        colour_file="colour-combos"
    else
        echo "Warning: colour-combos file not found (checked colour-combos.md and colour-combos), cannot select random profile" >&2
        return 1
    fi
    
    # Extract valid colour combination lines (skip markdown syntax, comments, empty lines)
    local combinations
    combinations=$(awk '
        NF && \
        $1 !~ /^#/ && \
        $1 !~ /^```/ && \
        $1 !~ /^\*\*/ && \
        $1 !~ /^\(c\)/ && \
        $1 !~ /^Copy/ && \
        $1 !~ /^Or/ && \
        $1 !~ /^The/ && \
        $1 !~ /^export/ && \
        $1 !~ /^Available/ && \
        $1 !~ /^Format:/ && \
        $1 !~ /^-/ && \
        $1 !~ /^##/ {
            # Check if line has exactly 3 fields (hostname, username, pwd colours)
            # and fields look like colour names (all caps, may contain underscores)
            if (NF == 3 && $1 ~ /^[A-Z_]+$/ && $2 ~ /^[A-Z_]+$/ && $3 ~ /^[A-Z_]+$/) {
                print $1 " " $2 " " $3
            }
        }
    ' "$colour_file")
    
    if [[ -z "$combinations" ]]; then
        echo "Warning: No valid colour combinations found in $colour_file" >&2
        return 1
    fi
    
    # Count combinations and select a random one
    local count
    count=$(echo "$combinations" | wc -l)
    
    # Generate random number between 1 and count
    local random_line
    if command -v shuf >/dev/null 2>&1; then
        random_line=$(echo "$combinations" | shuf -n 1)
    elif command -v gshuf >/dev/null 2>&1; then
        random_line=$(echo "$combinations" | gshuf -n 1)
    else
        # Fallback: use $RANDOM if available, otherwise use a simple hash
        local line_num
        if [[ -n "${RANDOM:-}" ]]; then
            line_num=$((RANDOM % count + 1))
        else
            # Use a simple hash based on current time
            line_num=$(( $(date +%s) % count + 1 ))
        fi
        random_line=$(echo "$combinations" | sed -n "${line_num}p")
    fi
    
    # Extract the three colours
    HOSTNAME_COLOUR=$(echo "$random_line" | awk '{print $1}')
    USERNAME_COLOUR=$(echo "$random_line" | awk '{print $2}')
    PWD_COLOUR=$(echo "$random_line" | awk '{print $3}')
    
    echo "Selected random colour profile:"
    echo "  Hostname: ${HOSTNAME_COLOUR}"
    echo "  Username: ${USERNAME_COLOUR}"
    echo "  PWD: ${PWD_COLOUR}"
}

# Generate config.mk
generate_config() {
    detect_distro
    finalize_package_target
    
    # Handle colour profile selection
    if [[ "$COLOUR_PROFILE" == "random" ]]; then
        select_random_colour_profile
    fi
    
    cat > "$CONFIG_FILE" <<EOF
# Cognitify build configuration
# Generated by configure script on $(date)

# Installation paths
PREFIX = ${PREFIX}
ETC_DIR = ${ETC_DIR}
CONFIG_DEST = \$(ETC_DIR)/bash.bashrc.d
COMPLETIONS_DEST = \$(ETC_DIR)/bash_completion.d
HOME_FILES_DEST = \$(shell getent passwd ${INSTALL_USER} | cut -d: -f6)

# User and group
INSTALL_USER = ${INSTALL_USER}
GROUP_NAME = cognitify

# Distribution information
DISTRO_ID = ${DISTRO_ID}
DISTRO_VERSION_ID = ${DISTRO_VERSION_ID:-}
PKG_MANAGER = ${PKG_MANAGER}
PKG_MANAGER_INSTALL = ${PKG_MANAGER_INSTALL}
PKG_MANAGER_UPDATE = ${PKG_MANAGER_UPDATE}

# Build options
INCLUDE_GUI = ${INCLUDE_GUI}
SKIP_PACKAGES = ${SKIP_PACKAGES}
DOCKER_MODE = ${DOCKER_MODE}
PACKAGE_TARGET = ${PACKAGE_TARGET}
INCLUDE_COCKPIT = ${INCLUDE_COCKPIT}
EXTENDED_COMPLETIONS = ${EXTENDED_COMPLETIONS}
EXTENDED_HOME_FILES = ${EXTENDED_HOME_FILES}
HOSTNAME_COLOUR = ${HOSTNAME_COLOUR}
USERNAME_COLOUR = ${USERNAME_COLOUR}
PWD_COLOUR = ${PWD_COLOUR}

# Source directories
SRC_DIR = src
CONFIG_SRC = \$(SRC_DIR)/bash.bashrc.d
HOME_FILES_SRC = \$(SRC_DIR)/home-files
HOME_FILES_EXTENDED_SRC = \$(SRC_DIR)/home-files-extended
COMPLETIONS_SRC = \$(SRC_DIR)/completions
COMPLETIONS_EXTENDED_SRC = \$(SRC_DIR)/completions-extended
PACKAGES_DIR = \$(SRC_DIR)/packages
BIN_SRC = \$(SRC_DIR)/usr/local/bin
DISTRO_FILES_SRC = \$(SRC_DIR)/distro-files

# Version
VERSION = $(cat version 2>/dev/null || echo "0.0.1")
EOF

    echo "Configuration generated: $CONFIG_FILE"
    echo ""
    echo "Configuration summary:"
    echo "  Distribution: ${DISTRO_ID} ${DISTRO_VERSION_ID:-}"
    echo "  Package Manager: ${PKG_MANAGER}"
    echo "  Installation Prefix: ${PREFIX}"
    echo "  Configuration Directory: ${ETC_DIR}"
    echo "  Install User: ${INSTALL_USER}"
    echo "  Include GUI: ${INCLUDE_GUI}"
    echo "  Skip Packages: ${SKIP_PACKAGES}"
    echo "  Docker Mode: ${DOCKER_MODE}"
    echo "  Package Target: ${PACKAGE_TARGET}"
    echo "  Include Cockpit: ${INCLUDE_COCKPIT}"
    echo "  Extended Completions: ${EXTENDED_COMPLETIONS}"
    echo "  Extended Home Files: ${EXTENDED_HOME_FILES}"
    if [[ -n "${HOSTNAME_COLOUR}" ]]; then
        echo "  Hostname Colour: ${HOSTNAME_COLOUR}"
    fi
    if [[ -n "${USERNAME_COLOUR}" ]]; then
        echo "  Username Colour: ${USERNAME_COLOUR}"
    fi
    if [[ -n "${PWD_COLOUR}" ]]; then
        echo "  PWD Colour: ${PWD_COLOUR}"
    fi
    echo ""
    echo "Next steps:"
    echo "  make          - Build the project"
    echo "  make install   - Install files and packages"
    echo "  make help      - Show more targets"
}

# Main
parse_args "$@"

# Handle distro packaging (must be after parse_args)
if [[ -n "${DISTRO_PACKAGE:-}" ]]; then
    if [[ ! -f "package-distro.sh" ]]; then
        echo "Error: package-distro.sh not found" >&2
        exit 1
    fi
    chmod +x package-distro.sh
    ./package-distro.sh "$DISTRO_PACKAGE"
    exit $?
fi

generate_config

