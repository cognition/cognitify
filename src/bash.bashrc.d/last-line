## complete-alias: register completions for every alias. Some distros never
## source /etc/bash_completion.d/complete_alias; define _complete_alias here if
## missing so `complete -F` does not point at a non-existent function.
## Fork: https://github.com/cognition/complete-alias

COMPAL_COMPLETE_ALIAS="/etc/bash_completion.d/complete_alias"

if [[ -f "$COMPAL_COMPLETE_ALIAS" ]]; then
    if ! declare -F _complete_alias >/dev/null 2>&1; then
        # shellcheck source=/dev/null
        source "$COMPAL_COMPLETE_ALIAS"
    fi
    if declare -F _complete_alias >/dev/null 2>&1 && ((${#BASH_ALIASES[@]} > 0)); then
        complete -F _complete_alias "${!BASH_ALIASES[@]}"
    fi
fi

unset COMPAL_COMPLETE_ALIAS

